<div class="flex items-center justify-between mb-6">
  <h1 class="text-xl font-semibold">Tasks</h1>
  <%= link_to "New Task", new_task_path,
      class: "px-4 py-2 bg-slate-800 text-white text-sm rounded hover:bg-slate-700" %>
</div>

<%= form_with url: tasks_path, method: :get,
    data: { controller: "search-form", turbo_frame: "task-results" } do |f| %>
  <div class="flex gap-3 items-end flex-wrap mb-6">
    <div>
      <%= f.label :query, "Search", class: "block text-xs font-medium mb-1" %>
      <%= f.text_field :query, value: params[:query], placeholder: "Title or AW-1234",
          class: "border rounded px-3 py-2 text-sm",
          data: { action: "input->search-form#search" } %>
    </div>
    <div>
      <%= f.label :customer_id, "Customer", class: "block text-xs font-medium mb-1" %>
      <%= f.collection_select :customer_id, @customers, :id, :name,
          { include_blank: "All customers", selected: params[:customer_id] },
          { class: "border rounded px-3 py-2 text-sm", data: { action: "change->search-form#submit" } } %>
    </div>
    <div>
      <%= f.label :project_code_id, "Project Code", class: "block text-xs font-medium mb-1" %>
      <%= f.select :project_code_id,
          options_for_select(
            [["Unassigned", "none"]] + @project_codes.map { |pc| ["#{pc.code} — #{pc.description}", pc.id] },
            params[:project_code_id]
          ),
          { include_blank: "All codes" },
          { class: "border rounded px-3 py-2 text-sm", data: { action: "change->search-form#submit" } } %>
    </div>
    <div>
      <%= f.label :status, "Status", class: "block text-xs font-medium mb-1" %>
      <%= f.select :status,
          [ [ "Active", "active" ], [ "Archived", "archived" ] ],
          { selected: params[:status] || "active" },
          { class: "border rounded px-3 py-2 text-sm", data: { action: "change->search-form#submit" } } %>
    </div>
    <div>
      <%= f.label :date_from, "Created since", class: "block text-xs font-medium mb-1" %>
      <%= f.date_field :date_from, value: params[:date_from],
          class: "border rounded px-3 py-2 text-sm",
          data: { action: "change->search-form#submit" } %>
    </div>
    <div class="flex items-center gap-2 pb-2">
      <%= f.check_box :billable, checked: params[:billable] == "true",
          class: "rounded border",
          data: { action: "change->search-form#submit" } %>
      <%= f.label :billable, "Billable only", class: "text-sm" %>
    </div>
    <%= f.submit "Filter", class: "px-3 py-2 bg-slate-100 dark:bg-slate-700 text-sm rounded hover:bg-slate-200 dark:hover:bg-slate-600 cursor-pointer" %>
  </div>
<% end %>

<%= turbo_frame_tag "task-results" do %>
  <table class="w-full text-sm">
    <thead>
      <tr class="border-b text-left text-slate-500">
        <th class="pb-2 font-medium"><%= sort_link("Title", "title", request.query_parameters) %></th>
        <th class="pb-2 font-medium hidden sm:table-cell"><%= sort_link("Customer", "customer", request.query_parameters) %></th>
        <th class="pb-2 font-medium hidden sm:table-cell"><%= sort_link("Project Code", "project_code", request.query_parameters) %></th>
        <th class="pb-2 font-medium hidden sm:table-cell">Billable</th>
        <th class="pb-2 font-medium hidden sm:table-cell"><%= sort_link("Created", "created_at", request.query_parameters) %></th>
        <th class="pb-2"></th>
      </tr>
    </thead>
    <tbody>
      <% @tasks.each do |task| %>
        <tr class="border-b even:bg-slate-100 dark:even:bg-slate-700 hover:bg-slate-200 dark:hover:bg-slate-600">
          <td class="py-1">
            <%= link_to task.title, task_path(task), class: "hover:underline font-medium", data: { turbo_frame: "_top" } %>
          </td>
          <td class="py-1 text-slate-600 dark:text-slate-400 hidden sm:table-cell"><%= task.customer.name %></td>
          <td class="py-1 font-mono text-xs text-slate-600 dark:text-slate-400 hidden sm:table-cell">
            <%= task.project_code&.code || "—" %>
          </td>
          <td class="py-1 hidden sm:table-cell">
            <% if task.billable? %>
              <span class="px-2 py-0.5 bg-green-100 dark:bg-green-900 text-green-700 dark:text-green-300 text-xs rounded-full">Billable</span>
            <% else %>
              <span class="px-2 py-0.5 bg-slate-100 dark:bg-slate-700 text-slate-500 text-xs rounded-full">Non-billable</span>
            <% end %>
          </td>
          <td class="py-1 text-xs text-slate-500 dark:text-slate-400 hidden sm:table-cell">
            <%= task.created_at.in_time_zone(current_timezone).strftime("%-d %b %Y") %>
          </td>
          <td class="py-1 text-right space-x-3">
            <%= link_to "Edit", edit_task_path(task), class: "text-xs text-slate-500 dark:text-slate-300 hover:underline", data: { turbo_frame: "_top" } %>
            <%= button_to task.active? ? "Archive" : "Restore",
                archive_task_path(task),
                method: :patch,
                class: "text-xs text-slate-500 dark:text-slate-300 hover:underline bg-transparent border-none cursor-pointer p-0",
                form: { class: "inline", data: { turbo_frame: "_top" } } %>
          </td>
        </tr>
      <% end %>
      <% if @tasks.empty? %>
        <tr>
          <td colspan="6" class="py-4 text-center text-slate-400">No tasks found.</td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% end %>
