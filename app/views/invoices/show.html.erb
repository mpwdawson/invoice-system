<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-xl font-semibold"><%= @invoice.invoice_number %></h1>
    <p class="text-sm text-slate-500 dark:text-slate-400">
      <%= @invoice.customer&.name %> — <%= @invoice.period_start %> – <%= @invoice.period_end %>
    </p>
  </div>
  <%= invoice_status_badge(@invoice.status) %>
</div>

<% if @invoice.invoice_lines.any? %>
  <ul class="space-y-2 mb-6">
    <% @invoice.invoice_lines.each do |line| %>
      <li class="text-sm text-slate-700 dark:text-slate-300 border-b dark:border-slate-700 pb-2"><%= line.description %></li>
    <% end %>
  </ul>
<% end %>

<div class="text-sm space-y-1 mb-6">
  <p>Total hours: <span class="font-medium text-slate-900 dark:text-white tabular-nums"><%= @invoice.total_hours %>h</span></p>
  <p>Rate: <span class="font-medium text-slate-900 dark:text-white">$<%= number_with_precision(@invoice.rate, precision: 2) %>/hr</span></p>
  <p>Total amount: <span class="font-medium text-slate-900 dark:text-white tabular-nums">$<%= number_with_precision(@invoice.total_amount, precision: 2) %></span></p>
  <% if @invoice.sent_at.present? %>
    <p>Sent: <span class="font-medium text-slate-900 dark:text-white"><%= @invoice.sent_at.in_time_zone(current_timezone).strftime("%-d %b %Y") %></span></p>
  <% end %>
  <% if @invoice.paid_at.present? %>
    <p>Paid: <span class="font-medium text-slate-900 dark:text-white"><%= @invoice.paid_at.in_time_zone(current_timezone).strftime("%-d %b %Y") %></span></p>
  <% end %>
</div>

<% if @invoice.ready? %>
  <%= button_to 'Mark as Sent', mark_sent_invoice_path(@invoice), method: :patch,
        data: { turbo_confirm: 'Mark this invoice as sent?' },
        class: 'px-3 py-1.5 text-sm rounded bg-slate-800 text-white dark:bg-slate-100 dark:text-slate-900' %>
<% elsif @invoice.sent? %>
  <%= button_to 'Mark as Paid', mark_paid_invoice_path(@invoice), method: :patch,
        data: { turbo_confirm: 'Mark this invoice as paid?' },
        class: 'px-3 py-1.5 text-sm rounded bg-slate-800 text-white dark:bg-slate-100 dark:text-slate-900' %>
<% end %>
