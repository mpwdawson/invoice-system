<% if tasks.any? %>
  <table class="w-full text-sm">
    <tbody>
      <% tasks.each do |task| %>
        <tr class="border-b even:bg-slate-100 dark:even:bg-slate-700 hover:bg-slate-200 dark:hover:bg-slate-600">
          <td class="py-1">
            <%= link_to task.title, task_path(task), class: "hover:underline", data: { turbo_frame: "_top" } %>
          </td>
          <td class="py-1 font-mono text-xs text-slate-500">
            <%= task.ticket_references.map(&:to_s).join(', ').presence || "—" %>
          </td>
          <td class="py-1 text-right">
            <%= button_to "[x]",
                  remove_task_customer_project_code_path(customer, project_code, task_id: task.id),
                  method: :delete,
                  form: { class: "inline" },
                  class: "text-xs text-slate-400 hover:text-red-500 bg-transparent border-none cursor-pointer p-0",
                  title: "Remove" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p class="text-sm text-slate-400">No tasks assigned yet.</p>
<% end %>
