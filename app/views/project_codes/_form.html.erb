<% if project_code.errors.any? %>
  <div class="mb-4 p-3 bg-red-50 dark:bg-red-950 border border-red-200 dark:border-red-800 rounded text-sm text-red-700 dark:text-red-300">
    <ul class="list-disc list-inside space-y-0.5">
      <% project_code.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<div class="space-y-3">
  <div>
    <%= f.label :code, class: "block text-sm font-medium mb-1" %>
    <%= f.text_field :code, class: "w-full border rounded px-3 py-2 text-sm font-mono",
        placeholder: "e.g. DSNSERV" %>
  </div>
  <div>
    <%= f.label :description, class: "block text-sm font-medium mb-1" %>
    <%= f.text_field :description, class: "w-full border rounded px-3 py-2 text-sm",
        placeholder: "e.g. Design Services Phase 1" %>
  </div>
  <div class="flex gap-3 items-center">
    <%= f.submit class: "px-4 py-2 bg-slate-800 text-white text-sm rounded hover:bg-slate-700 cursor-pointer" %>
    <%= link_to "Cancel", customer_project_codes_path(customer),
        class: "text-sm text-slate-500 hover:underline" %>
  </div>
</div>
