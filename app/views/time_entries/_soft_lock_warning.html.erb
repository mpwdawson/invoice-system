<div class="px-3 py-2 text-sm">
  <p class="text-xs text-amber-700 dark:text-amber-300 mb-2">
    This entry is on a sent invoice. Deleting it won't change the invoice total. Continue?
  </p>
  <div class="flex items-center gap-3">
    <%= button_to 'Yes, delete', time_entry_path(time_entry), method: :delete,
        params: { force: true },
        class: 'text-xs text-red-600 hover:underline bg-transparent border-0 p-0 cursor-pointer' %>
    <%= link_to 'Cancel', time_entry_path(time_entry),
        class: 'text-xs text-slate-500 hover:underline' %>
  </div>
</div>
