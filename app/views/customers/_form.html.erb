<%= form_with model: customer do |f| %>
  <% if customer.errors.any? %>
    <div class="mb-4 p-3 bg-red-50 dark:bg-red-950 border border-red-200 dark:border-red-800 rounded text-sm text-red-700 dark:text-red-300">
      <ul class="list-disc list-inside space-y-0.5">
        <% customer.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>
  <div class="space-y-4 max-w-lg">
    <div>
      <%= f.label :name, class: "block text-sm font-medium mb-1" %>
      <%= f.text_field :name, class: "w-full border rounded px-3 py-2 text-sm" %>
    </div>
    <div>
      <%= f.label :invoice_prefix, "Invoice Prefix", class: "block text-sm font-medium mb-1" %>
      <%= f.text_field :invoice_prefix, class: "w-full border rounded px-3 py-2 text-sm" %>
    </div>
    <div>
      <%= f.label :contact_name, "Contact Name", class: "block text-sm font-medium mb-1" %>
      <%= f.text_field :contact_name, class: "w-full border rounded px-3 py-2 text-sm" %>
    </div>
    <div>
      <%= f.label :contact_email, "Contact Email", class: "block text-sm font-medium mb-1" %>
      <%= f.email_field :contact_email, class: "w-full border rounded px-3 py-2 text-sm" %>
    </div>
    <div>
      <%= f.label :address, class: "block text-sm font-medium mb-1" %>
      <%= f.text_area :address, rows: 3, class: "w-full border rounded px-3 py-2 text-sm" %>
    </div>
    <div class="flex items-center gap-2">
      <%= f.check_box :requires_project_codes, class: "rounded" %>
      <%= f.label :requires_project_codes, "Requires project codes on invoice", class: "text-sm" %>
    </div>
    <%= f.submit class: "mt-2 px-4 py-2 bg-slate-800 text-white text-sm rounded hover:bg-slate-700 cursor-pointer" %>
  </div>
<% end %>
