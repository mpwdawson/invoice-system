<%= turbo_stream.replace "assigned-tasks-#{@project_code.id}" do %>
  <%= turbo_frame_tag "assigned-tasks-#{@project_code.id}" do %>
    <%= render 'assigned_tasks', tasks: @tasks, customer: @customer, project_code: @project_code %>
  <% end %>
<% end %>

<%= turbo_stream.replace "task-search-results-#{@project_code.id}" do %>
  <turbo-frame id="task-search-results-<%= @project_code.id %>"></turbo-frame>
<% end %>
