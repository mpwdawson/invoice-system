<div class="max-w-2xl">
  <%= render 'nav' %>

  <h1 class="text-lg font-semibold mb-6">Daily Log</h1>

  <%= form_with url: daily_log_report_path, method: :get, class: 'flex flex-wrap gap-3 items-end mb-8' do |f| %>
    <div>
      <label class="block text-xs text-slate-500 mb-1">Customer</label>
      <%= select_tag :customer_id,
            options_from_collection_for_select(@customers, :id, :name, @customer&.id),
            prompt: 'Select customer',
            class: 'rounded border px-2 py-1.5 text-sm dark:bg-slate-800 dark:border-slate-600' %>
    </div>
    <div>
      <label class="block text-xs text-slate-500 mb-1">From</label>
      <%= date_field_tag :from, @from,
            class: 'rounded border px-2 py-1.5 text-sm dark:bg-slate-800 dark:border-slate-600' %>
    </div>
    <div>
      <label class="block text-xs text-slate-500 mb-1">To</label>
      <%= date_field_tag :to, @to,
            class: 'rounded border px-2 py-1.5 text-sm dark:bg-slate-800 dark:border-slate-600' %>
    </div>
    <button type="submit" class="px-3 py-1.5 text-sm rounded bg-slate-800 text-white dark:bg-slate-100 dark:text-slate-900">
      Run
    </button>
  <% end %>

  <% if @result %>
    <% if @result.days.any? %>
      <div class="space-y-6">
        <% @result.days.each do |day| %>
          <div>
            <h2 class="text-sm font-semibold mb-2"><%= day.date.strftime('%A, %B %-d') %></h2>
            <table class="w-full text-sm">
              <tbody class="divide-y dark:divide-slate-700">
                <% day.time_entries.each do |entry| %>
                  <tr>
                    <td class="py-2 text-slate-600 dark:text-slate-400"><%= entry.task.title %></td>
                    <td class="py-2">
                      <% if entry.billed %>
                        <span class="text-xs px-1.5 py-0.5 rounded bg-emerald-100 text-emerald-700 dark:bg-emerald-900 dark:text-emerald-300">billed</span>
                      <% else %>
                        <span class="text-xs px-1.5 py-0.5 rounded bg-amber-100 text-amber-700 dark:bg-amber-900 dark:text-amber-300">unbilled</span>
                      <% end %>
                    </td>
                    <td class="py-2 text-right tabular-nums"><%= entry.hours %>h</td>
                  </tr>
                <% end %>
              </tbody>
              <tfoot>
                <tr class="border-t dark:border-slate-600 font-semibold">
                  <td class="pt-2" colspan="2">Subtotal</td>
                  <td class="pt-2 text-right tabular-nums"><%= day.hours %>h</td>
                </tr>
              </tfoot>
            </table>
          </div>
        <% end %>
      </div>

      <div class="flex justify-between font-semibold text-sm mt-6 pt-3 border-t dark:border-slate-600">
        <span>Total</span>
        <span class="tabular-nums"><%= @result.total_hours %>h</span>
      </div>
    <% else %>
      <p class="text-sm text-slate-400">No time entries found for this period.</p>
    <% end %>
  <% end %>
</div>
