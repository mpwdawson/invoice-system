<div class="flex items-center justify-between mb-4">
  <div>
    <p class="text-xs text-slate-500 mb-1"><%= link_to @customer.name, customer_path(@customer), class: "hover:underline" %></p>
    <h1 class="text-xl font-semibold">Project Codes</h1>
  </div>
  <div class="flex items-center gap-3">
    <%= link_to "Import CSV", import_form_customer_project_codes_path(@customer),
        class: "text-sm text-slate-500 hover:text-slate-700 dark:hover:text-slate-300",
        data: { turbo_frame: "project-code-import" } %>
    <%= link_to "New Code", new_customer_project_code_path(@customer),
        class: "px-4 py-2 bg-slate-800 text-white text-sm rounded hover:bg-slate-700" %>
  </div>
</div>

<%= turbo_frame_tag "project-code-import", class: "block" %>

<table class="w-full text-sm">
  <thead>
    <tr class="border-b text-left text-slate-500">
      <th class="pb-2 font-medium">Code</th>
      <th class="pb-2 font-medium">Description</th>
      <th class="pb-2 font-medium">Status</th>
      <th class="pb-2"></th>
    </tr>
  </thead>
  <tbody>
    <% @project_codes.each do |code| %>
      <tr class="border-b hover:bg-slate-50 dark:hover:bg-slate-800 <%= "opacity-50" unless code.active? %>">
        <td class="py-1 font-mono text-xs">
          <%= link_to code.code, customer_project_code_path(@customer, code), class: "hover:underline" %>
        </td>
        <td class="py-1"><%= code.description %></td>
        <td class="py-1 text-slate-500"><%= code.active? ? "Active" : "Archived" %></td>
        <td class="py-1 text-right space-x-3">
          <%= link_to "Edit", edit_customer_project_code_path(@customer, code),
              class: "text-xs text-slate-500 hover:underline" %>
          <%= button_to code.active? ? "Archive" : "Unarchive",
              archive_customer_project_code_path(@customer, code),
              method: :patch,
              form: { class: "inline" },
              class: "text-xs text-slate-500 hover:underline bg-transparent border-none cursor-pointer p-0" %>
          <% if code.tasks.empty? %>
            <%= button_to "Delete",
                customer_project_code_path(@customer, code),
                method: :delete,
                form: { class: "inline" },
                data: { turbo_confirm: "Delete #{code.code}? This cannot be undone." },
                class: "text-xs text-red-400 hover:underline bg-transparent border-none cursor-pointer p-0" %>
          <% end %>
        </td>
      </tr>
    <% end %>
    <% if @project_codes.empty? %>
      <tr>
        <td colspan="4" class="py-4 text-center text-slate-400">No project codes yet.</td>
      </tr>
    <% end %>
  </tbody>
</table>
