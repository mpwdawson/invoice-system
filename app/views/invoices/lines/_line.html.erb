<div id="<%= dom_id(line) %>"
     class="border rounded p-3 dark:border-slate-700"
     draggable="true"
     data-controller="disclosure"
     data-sortable-target="item"
     data-line-id="<%= line.id %>"
     data-action="dragstart->sortable#start dragover->sortable#over dragend->sortable#end">

  <div data-disclosure-target="trigger" class="flex items-start justify-between gap-3 cursor-move">
    <div>
      <p class="text-sm text-slate-900 dark:text-white"><%= line.description %></p>
      <% selected_tasks = available_tasks.select { |task| Array(line.task_ids).include?(task.id) } %>
      <% if selected_tasks.any? %>
        <div class="flex flex-wrap gap-1 mt-1">
          <% selected_tasks.each do |task| %>
            <span class="text-xs px-1.5 py-0.5 rounded bg-slate-100 text-slate-500 dark:bg-slate-700 dark:text-slate-400"><%= task.title %></span>
          <% end %>
        </div>
      <% end %>
    </div>
    <div class="flex items-center gap-3 shrink-0">
      <button type="button" data-action="disclosure#reveal"
              class="text-slate-400 hover:text-slate-700 dark:hover:text-slate-200">✎</button>
      <%= link_to '×', invoice_line_path(invoice, line),
            data: { turbo_method: :delete, turbo_confirm: 'Delete this line?' },
            class: 'text-red-400 hover:text-red-600 leading-none',
            aria: { label: 'Delete line' } %>
    </div>
  </div>

  <div data-disclosure-target="content" hidden class="mt-3">
    <%= form_with model: line, url: invoice_line_path(invoice, line), method: :patch do |f| %>
      <%= render 'invoices/lines/line_fields', f: f, available_tasks: available_tasks %>
      <div class="flex items-center gap-2 mt-2">
        <%= f.submit 'Save', class: 'px-3 py-1 text-sm rounded bg-slate-800 text-white dark:bg-slate-100 dark:text-slate-900' %>
        <button type="button" data-action="disclosure#conceal" class="text-sm text-slate-500 hover:underline">Cancel</button>
      </div>
    <% end %>
  </div>
</div>
