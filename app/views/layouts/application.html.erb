<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Invoice System" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Invoice System">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="flex h-screen bg-white dark:bg-slate-900 text-slate-900 dark:text-slate-100">

    <aside id="main-sidebar"
           data-turbo-permanent
           data-controller="dark-mode"
           class="flex flex-col w-56 shrink-0 h-screen bg-slate-800 dark:bg-slate-950 text-slate-100 border-r border-slate-700 dark:border-slate-800">

      <div class="flex items-center justify-between px-4 py-4 border-b border-slate-700">
        <%= link_to "Invoice", root_path, class: "text-sm font-semibold tracking-wide text-slate-200 hover:text-white" %>
        <button data-action="dark-mode#toggle"
                class="text-slate-400 hover:text-slate-200 transition"
                aria-label="Toggle dark mode">☀/🌙</button>
      </div>

      <nav class="flex flex-col gap-0.5 px-2 py-4 flex-1">
        <%= link_to "Log Time",  root_path, class: "block px-3 py-2 rounded text-sm text-slate-300 hover:bg-slate-700 hover:text-white transition" %>
        <%= link_to "Tasks",     tasks_path, class: "block px-3 py-2 rounded text-sm text-slate-300 hover:bg-slate-700 hover:text-white transition" %>
        <%= link_to "Customers", customers_path, class: "block px-3 py-2 rounded text-sm text-slate-300 hover:bg-slate-700 hover:text-white transition" %>
        <%= link_to "Reports",   monthly_hours_report_path, class: "block px-3 py-2 rounded text-sm text-slate-300 hover:bg-slate-700 hover:text-white transition" %>
        <%= link_to "Invoices",  invoices_path, class: "block px-3 py-2 rounded text-sm text-slate-300 hover:bg-slate-700 hover:text-white transition" %>
        <%= link_to "Settings",  settings_path, class: "block px-3 py-2 rounded text-sm text-slate-300 hover:bg-slate-700 hover:text-white transition" %>
      </nav>

      <div class="px-2 py-4 border-t border-slate-700">
        <%= button_to "Sign out", logout_path, method: :delete,
              class: "w-full text-left px-3 py-2 rounded text-sm text-slate-400 hover:bg-slate-700 hover:text-white transition" %>
      </div>
    </aside>

    <div class="flex-1 overflow-auto">
      <% flash.each do |type, message| %>
        <p id="flash-<%= type %>" class="px-6 py-3 text-sm"><%= message %></p>
      <% end %>
      <main class="p-6">
        <%= yield %>
      </main>
    </div>

  </body>
</html>
