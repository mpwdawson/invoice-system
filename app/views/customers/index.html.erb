<div class="flex items-center justify-between mb-6">
  <h1 class="text-xl font-semibold">Customers</h1>
  <%= link_to "New Customer", new_customer_path, class: "px-4 py-2 bg-slate-800 text-white text-sm rounded hover:bg-slate-700" %>
</div>

<table class="w-full text-sm">
  <thead>
    <tr class="border-b text-left text-slate-500">
      <th class="pb-2 font-medium">Name</th>
      <th class="pb-2 font-medium">Invoice Prefix</th>
      <th class="pb-2 font-medium">Current Rate</th>
      <th class="pb-2 font-medium">Project Codes</th>
      <th class="pb-2"></th>
    </tr>
  </thead>
  <tbody>
    <% @customers.each do |customer| %>
      <% current_rate = CustomerRate.current_for(customer, user_date) %>
      <tr class="border-b even:bg-slate-100 dark:even:bg-slate-700 hover:bg-slate-200 dark:hover:bg-slate-600">
        <td class="py-1"><%= link_to customer.name, customer_path(customer), class: "font-medium hover:underline" %></td>
        <td class="py-1 text-slate-500"><%= customer.invoice_prefix.presence || "—" %></td>
        <td class="py-1"><%= current_rate ? "$#{number_with_precision(current_rate.rate, precision: 2)}/hr" : "—" %></td>
        <td class="py-1"><%= customer.project_codes.size > 0 ? "#{customer.project_codes.size} code#{"s" if customer.project_codes.size != 1}" : "—" %></td>
        <td class="py-1 text-right"><%= link_to "Edit", edit_customer_path(customer), class: "text-xs text-slate-500 dark:text-slate-300 hover:underline" %></td>
      </tr>
    <% end %>
    <% if @customers.empty? %>
      <tr>
        <td colspan="5" class="py-4 text-center text-slate-400">No customers yet.</td>
      </tr>
    <% end %>
  </tbody>
</table>
