<div class="max-w-2xl">
  <%= render 'nav' %>

  <h1 class="text-lg font-semibold mb-6">Task Totals</h1>

  <%= form_with url: task_totals_report_path, method: :get, class: 'flex flex-wrap gap-3 items-end mb-8' do |f| %>
    <div>
      <label class="block text-xs text-slate-500 mb-1">Customer</label>
      <%= select_tag :customer_id,
            options_from_collection_for_select(@customers, :id, :name, @customer&.id),
            prompt: 'Select customer',
            class: 'rounded border px-2 py-1.5 text-sm dark:bg-slate-800 dark:border-slate-600' %>
    </div>
    <div>
      <label class="block text-xs text-slate-500 mb-1">Project Code</label>
      <%= select_tag :project_code_id,
            options_from_collection_for_select(@project_codes, :id, :code, @project_code&.id),
            prompt: 'All',
            disabled: @customer.nil?,
            class: 'rounded border px-2 py-1.5 text-sm dark:bg-slate-800 dark:border-slate-600' %>
    </div>
    <div>
      <label class="block text-xs text-slate-500 mb-1">Status</label>
      <%= select_tag :status,
            options_for_select([['All', ''], ['Active', 'active'], ['Archived', 'archived']], @status),
            class: 'rounded border px-2 py-1.5 text-sm dark:bg-slate-800 dark:border-slate-600' %>
    </div>
    <div>
      <label class="block text-xs text-slate-500 mb-1">Billable</label>
      <%= select_tag :billable,
            options_for_select([['All', ''], ['Billable', 'true'], ['Non-billable', 'false']], @billable.nil? ? '' : @billable.to_s),
            class: 'rounded border px-2 py-1.5 text-sm dark:bg-slate-800 dark:border-slate-600' %>
    </div>
    <div>
      <label class="block text-xs text-slate-500 mb-1">From</label>
      <%= date_field_tag :from, @from,
            class: 'rounded border px-2 py-1.5 text-sm dark:bg-slate-800 dark:border-slate-600' %>
    </div>
    <div>
      <label class="block text-xs text-slate-500 mb-1">To</label>
      <%= date_field_tag :to, @to,
            class: 'rounded border px-2 py-1.5 text-sm dark:bg-slate-800 dark:border-slate-600' %>
    </div>
    <button type="submit" class="px-3 py-1.5 text-sm rounded bg-slate-800 text-white dark:bg-slate-100 dark:text-slate-900">
      Run
    </button>
  <% end %>

  <% if @result %>
    <% if @result.rows.any? %>
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b dark:border-slate-700 text-left text-xs text-slate-500">
            <th class="pb-2 font-medium">Task</th>
            <th class="pb-2 font-medium">Project Code</th>
            <th class="pb-2 font-medium">Billable</th>
            <th class="pb-2 font-medium text-right">Hours</th>
          </tr>
        </thead>
        <tbody class="divide-y dark:divide-slate-700">
          <% @result.rows.each do |row| %>
            <tr>
              <td class="py-2 text-slate-600 dark:text-slate-400"><%= row.task.title %></td>
              <td class="py-2 font-mono text-xs"><%= row.task.project_code&.code %></td>
              <td class="py-2"><%= row.task.billable? ? 'Yes' : 'No' %></td>
              <td class="py-2 text-right tabular-nums"><%= row.hours %>h</td>
            </tr>
          <% end %>
        </tbody>
        <tfoot>
          <tr class="border-t dark:border-slate-600 font-semibold">
            <td class="pt-3" colspan="3">Total</td>
            <td class="pt-3 text-right tabular-nums"><%= @result.total_hours %>h</td>
          </tr>
        </tfoot>
      </table>
    <% else %>
      <p class="text-sm text-slate-400">No time entries found for this period.</p>
    <% end %>
  <% end %>
</div>
