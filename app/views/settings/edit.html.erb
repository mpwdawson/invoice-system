<h1 class="text-xl font-semibold mb-6">Settings</h1>

<%= form_with model: @profile, url: settings_path, method: :patch do |f| %>
  <% if @profile.errors.any? %>
    <div class="mb-4 p-3 bg-red-50 dark:bg-red-950 border border-red-200 dark:border-red-800 rounded text-sm text-red-700 dark:text-red-300">
      <ul class="list-disc list-inside space-y-0.5">
        <% @profile.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>
  <div class="space-y-4 max-w-lg">
    <div>
      <%= f.label :name, class: "block text-sm font-medium mb-1" %>
      <%= f.text_field :name, class: "w-full border rounded px-3 py-2 text-sm" %>
    </div>
    <div>
      <%= f.label :email, class: "block text-sm font-medium mb-1" %>
      <%= f.email_field :email, class: "w-full border rounded px-3 py-2 text-sm" %>
    </div>
    <div>
      <%= f.label :phone, "Phone", class: "block text-sm font-medium mb-1" %>
      <%= f.text_field :phone, class: "w-full border rounded px-3 py-2 text-sm" %>
    </div>
    <div>
      <%= f.label :address, class: "block text-sm font-medium mb-1" %>
      <%= f.text_area :address, rows: 3, class: "w-full border rounded px-3 py-2 text-sm" %>
    </div>
    <div>
      <%= f.label :tax_number, "Tax Number", class: "block text-sm font-medium mb-1" %>
      <%= f.text_field :tax_number, class: "w-full border rounded px-3 py-2 text-sm" %>
    </div>
    <div>
      <%= f.label :bank_details, "Bank Details", class: "block text-sm font-medium mb-1" %>
      <%= f.text_area :bank_details, rows: 3, class: "w-full border rounded px-3 py-2 text-sm" %>
    </div>
    <div>
      <%= f.label :timezone, "Timezone", class: "block text-sm font-medium mb-1" %>
      <%= f.time_zone_select :timezone,
          ActiveSupport::TimeZone.us_zones,
          { include_blank: false },
          class: "w-full border rounded px-3 py-2 text-sm" %>
    </div>
    <%= f.submit "Save", class: "mt-2 px-4 py-2 bg-slate-800 text-white text-sm rounded hover:bg-slate-700" %>
  </div>
<% end %>
