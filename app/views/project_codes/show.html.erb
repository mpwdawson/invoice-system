<div class="flex items-center justify-between mb-6">
  <div>
    <p class="text-xs text-slate-500 mb-1">
      <%= link_to @customer.name, customer_path(@customer), class: "hover:underline" %> /
      <%= link_to "Project Codes", customer_project_codes_path(@customer), class: "hover:underline" %>
    </p>
    <h1 class="text-xl font-semibold font-mono"><%= @project_code.code %></h1>
  </div>
  <%= link_to "Edit", edit_customer_project_code_path(@customer, @project_code),
      class: "px-4 py-2 bg-slate-800 text-white text-sm rounded hover:bg-slate-700" %>
</div>

<dl class="space-y-2 text-sm max-w-lg mb-8">
  <div class="flex gap-4">
    <dt class="w-32 text-slate-500 shrink-0">Description</dt>
    <dd><%= @project_code.description %></dd>
  </div>
  <div class="flex gap-4">
    <dt class="w-32 text-slate-500 shrink-0">Status</dt>
    <dd><%= @project_code.active? ? "Active" : "Archived" %></dd>
  </div>
</dl>

<h2 class="text-base font-semibold mb-3">Tasks (<%= @tasks.size %>)</h2>

<% if @tasks.any? %>
  <table class="w-full text-sm">
    <thead>
      <tr class="border-b text-left text-slate-500">
        <th class="pb-2 font-medium">Title</th>
        <th class="pb-2 font-medium">Status</th>
        <th class="pb-2 font-medium">Billable</th>
        <th class="pb-2 font-medium text-right">Hours logged</th>
      </tr>
    </thead>
    <tbody>
      <% @tasks.each do |task| %>
        <tr class="border-b even:bg-slate-100 dark:even:bg-slate-700 hover:bg-slate-200 dark:hover:bg-slate-600 <%= "opacity-50" if task.archived? %>">
          <td class="py-1">
            <%= link_to task.title, task_path(task), class: "hover:underline" %>
          </td>
          <td class="py-1 text-slate-500 capitalize"><%= task.status %></td>
          <td class="py-1 text-slate-500"><%= task.billable? ? "Yes" : "No" %></td>
          <td class="py-1 text-right font-mono text-xs">
            <% total = task.time_entries.sum(&:hours) %>
            <%= total.positive? ? "#{total}h" : "—" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p class="text-sm text-slate-400">No tasks assigned to this project code yet.</p>
<% end %>
