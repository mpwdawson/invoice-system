<div class="max-w-2xl">
  <%= render 'progress' %>

  <%= render @step_partial %>

  <div class="flex justify-between mt-8 pt-4 border-t dark:border-slate-700">
    <% unless @first_step %>
      <%= link_to 'Back', invoice_wizard_step_path(@invoice, step: @step - 1),
            class: 'px-3 py-1.5 text-sm rounded border dark:border-slate-600 text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800' %>
    <% else %>
      <span></span>
    <% end %>

    <% unless @last_step %>
      <%= button_to 'Next', invoice_wizard_step_path(@invoice, step: @step + 1), method: :patch,
            class: 'px-3 py-1.5 text-sm rounded bg-slate-800 text-white dark:bg-slate-100 dark:text-slate-900' %>
    <% end %>
  </div>
</div>
