<div class="mb-2">
  <%= f.text_area :description, required: true, rows: 2,
        class: 'w-full rounded border px-2 py-1.5 text-sm dark:bg-slate-800 dark:border-slate-600' %>
</div>
<% if available_tasks.any? %>
  <div class="flex flex-wrap gap-x-4 gap-y-1">
    <%= f.collection_check_boxes :task_ids, available_tasks, :id, :title do |b| %>
      <label class="flex items-center gap-1.5 text-xs text-slate-500 dark:text-slate-400">
        <%= b.check_box(class: 'rounded') %>
        <%= b.text %>
      </label>
    <% end %>
  </div>
<% end %>
