<div class="flex items-center justify-between mb-6">
  <h1 class="text-xl font-semibold">Tasks</h1>
  <%= link_to "New Task", new_task_path,
      class: "px-4 py-2 bg-slate-800 text-white text-sm rounded hover:bg-slate-700" %>
</div>

<%= form_with url: tasks_path, method: :get, data: { turbo_action: "replace" } do |f| %>
  <div class="flex gap-3 items-end flex-wrap mb-6">
    <div>
      <%= f.label :customer_id, "Customer", class: "block text-xs font-medium mb-1" %>
      <%= f.collection_select :customer_id, @customers, :id, :name,
          { include_blank: "All customers", selected: params[:customer_id] },
          { class: "border rounded px-3 py-2 text-sm" } %>
    </div>
    <div>
      <%= f.label :status, "Status", class: "block text-xs font-medium mb-1" %>
      <%= f.select :status,
          [ [ "Active", "active" ], [ "Archived", "archived" ] ],
          { selected: params[:status] || "active" },
          { class: "border rounded px-3 py-2 text-sm" } %>
    </div>
    <div class="flex items-center gap-2 pb-2">
      <%= f.check_box :billable, checked: params[:billable] == "true", class: "rounded border" %>
      <%= f.label :billable, "Billable only", class: "text-sm" %>
    </div>
    <%= f.submit "Filter", class: "px-3 py-2 bg-slate-100 dark:bg-slate-700 text-sm rounded hover:bg-slate-200 dark:hover:bg-slate-600 cursor-pointer" %>
  </div>
<% end %>

<table class="w-full text-sm">
  <thead>
    <tr class="border-b text-left text-slate-500">
      <th class="pb-2 font-medium">Title</th>
      <th class="pb-2 font-medium">Customer</th>
      <th class="pb-2 font-medium">Project Code</th>
      <th class="pb-2 font-medium">Billable</th>
      <th class="pb-2"></th>
    </tr>
  </thead>
  <tbody>
    <% @tasks.each do |task| %>
      <tr class="border-b hover:bg-slate-50 dark:hover:bg-slate-800">
        <td class="py-3">
          <%= link_to task.title, task_path(task), class: "hover:underline font-medium" %>
        </td>
        <td class="py-3 text-slate-600 dark:text-slate-400"><%= task.customer.name %></td>
        <td class="py-3 font-mono text-xs text-slate-600 dark:text-slate-400">
          <%= task.project_code&.code || "—" %>
        </td>
        <td class="py-3">
          <% if task.billable? %>
            <span class="px-2 py-0.5 bg-green-100 dark:bg-green-900 text-green-700 dark:text-green-300 text-xs rounded-full">Billable</span>
          <% else %>
            <span class="px-2 py-0.5 bg-slate-100 dark:bg-slate-700 text-slate-500 text-xs rounded-full">Non-billable</span>
          <% end %>
        </td>
        <td class="py-3 text-right space-x-3">
          <%= link_to "Edit", edit_task_path(task), class: "text-xs text-slate-500 hover:underline" %>
          <%= button_to task.active? ? "Archive" : "Restore",
              archive_task_path(task),
              method: :patch,
              class: "text-xs text-slate-500 hover:underline bg-transparent border-none cursor-pointer p-0" %>
        </td>
      </tr>
    <% end %>
    <% if @tasks.empty? %>
      <tr>
        <td colspan="5" class="py-6 text-center text-slate-400">No tasks found.</td>
      </tr>
    <% end %>
  </tbody>
</table>
