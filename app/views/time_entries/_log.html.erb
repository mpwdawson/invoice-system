<% log_entries.each do |group| %>
  <div class="mb-6">
    <div class="flex items-center justify-between mb-2">
      <div class="flex items-center gap-3">
        <span class="text-sm font-semibold">
          <%= group.date == Date.current ? "Today" : group.date.strftime("%-d %b") %>
        </span>
        <% if group.total_hours > 0 %>
          <span class="text-xs text-slate-400"><%= group.total_hours %>h</span>
        <% end %>
      </div>
      <button type="button"
              data-action="time-entry-form#setDate"
              data-date="<%= group.date %>"
              class="text-xs text-slate-400 hover:text-slate-600 dark:hover:text-slate-300">
        + Add entry
      </button>
    </div>

    <% if group.items.any? %>
      <div class="divide-y dark:divide-slate-700 border rounded dark:border-slate-700">
        <% group.items.each do |entry| %>
          <%= turbo_frame_tag dom_id(entry) do %>
            <div class="flex items-center gap-3 px-3 py-2 text-sm">
              <span class="flex-1 font-medium truncate"><%= entry.task.title %></span>
              <% if entry.task.project_code %>
                <span class="font-mono text-xs text-slate-400"><%= entry.task.project_code.code %></span>
              <% end %>
              <% if entry.invoice_id? %>
                <span class="text-xs px-1.5 py-0.5 rounded bg-green-100 text-green-700 dark:bg-green-900 dark:text-green-300">billed</span>
              <% else %>
                <span class="text-xs px-1.5 py-0.5 rounded bg-slate-100 text-slate-500 dark:bg-slate-700 dark:text-slate-400">unbilled</span>
              <% end %>
              <span class="tabular-nums text-slate-600 dark:text-slate-300"><%= entry.hours %>h</span>
              <button type="button"
                      class="text-slate-300 dark:text-slate-600 cursor-default"
                      disabled>&#9998;</button>
            </div>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <p class="text-xs text-slate-300 dark:text-slate-600 pl-1">—</p>
    <% end %>
  </div>
<% end %>
