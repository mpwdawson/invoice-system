# Auth — SHA256 hex digest of your password
# Generate with: echo -n "your_password" | sha256sum
APP_PASSWORD_DIGEST=

# LLM (B-24 — leave blank until that chunk)
LLM_ENDPOINT=http://192.168.1.x:11434/v1
LLM_MODEL=qwen2.5-coder:32b
LLM_TIMEOUT=30

# Kamal registry auth (see .kamal/secrets) — the local registry has no real
# auth, this just needs to be non-empty.
KAMAL_REGISTRY_PASSWORD=

# Kamal deploy target (see config/deploy.yml). NOT loaded from .env — Kamal's
# ERB reads these straight from the shell environment, so export them in the
# deploy host's shell rc (e.g. ~/.bashrc) instead.
# DEPLOY_HOST_IP=203.0.113.10
# DEPLOY_PORT=3007
# DEPLOY_SSH_USER=deploy
