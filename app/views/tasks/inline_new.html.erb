<%= turbo_frame_tag "task-search-results" do %>
  <%= form_with model: @task, url: inline_create_tasks_path do |f| %>
    <div class="border rounded shadow-lg bg-white dark:bg-slate-800 dark:border-slate-600 p-3 space-y-3">
      <p class="text-xs font-semibold text-slate-500 uppercase tracking-wide">New Task</p>

      <% if @task.errors.any? %>
        <p class="text-xs text-red-600"><%= @task.errors.full_messages.first %></p>
      <% end %>

      <div>
        <%= f.label :title, class: "block text-xs font-medium mb-1" %>
        <%= f.text_field :title,
            class: "w-full border rounded px-2 py-1.5 text-sm dark:bg-slate-700 dark:border-slate-600" %>
      </div>

      <div>
        <%= f.label :customer_id, "Customer", class: "block text-xs font-medium mb-1" %>
        <%= f.collection_select :customer_id, @customers, :id, :name,
            { include_blank: "Select a customer" },
            { class: "w-full border rounded px-2 py-1.5 text-sm dark:bg-slate-700 dark:border-slate-600" } %>
      </div>

      <div>
        <%= f.label :project_code_id, "Project Code", class: "block text-xs font-medium mb-1" %>
        <%= f.grouped_collection_select :project_code_id,
            @customers.select { |c| @project_codes.any? { |pc| pc.customer_id == c.id } },
            ->(c) { @project_codes.select { |pc| pc.customer_id == c.id } },
            :name, :id,
            ->(pc) { "#{pc.code} — #{pc.description}" },
            { include_blank: "None" },
            { class: "w-full border rounded px-2 py-1.5 text-sm dark:bg-slate-700 dark:border-slate-600" } %>
      </div>

      <div>
        <%= label_tag :ticket_ref, "Ticket #", class: "block text-xs font-medium mb-1" %>
        <%= text_field_tag :ticket_ref, @ticket_ref || params[:ticket_ref],
            placeholder: "AW-1234 (optional)",
            class: "w-full border rounded px-2 py-1.5 text-sm dark:bg-slate-700 dark:border-slate-600" %>
      </div>

      <div class="pt-1 flex items-center gap-3">
        <%= f.submit "Create Task",
            class: "px-3 py-1.5 bg-slate-800 text-white text-xs rounded hover:bg-slate-700 dark:bg-slate-600 cursor-pointer" %>
        <%= link_to "Cancel", search_tasks_path(query: params[:title], customer_id: params[:customer_id]),
            class: "text-xs text-slate-500 hover:text-slate-700 dark:hover:text-slate-300" %>
      </div>
    </div>
  <% end %>
<% end %>
