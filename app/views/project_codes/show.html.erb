<div class="flex items-center justify-between mb-6">
  <div>
    <p class="text-xs text-slate-500 mb-1">
      <%= link_to @customer.name, customer_path(@customer), class: "hover:underline" %> /
      <%= link_to "Project Codes", customer_project_codes_path(@customer), class: "hover:underline" %>
    </p>
    <h1 class="text-xl font-semibold font-mono"><%= @project_code.code %></h1>
  </div>
  <%= link_to "Edit", edit_customer_project_code_path(@customer, @project_code),
      class: "px-4 py-2 bg-slate-800 text-white text-sm rounded hover:bg-slate-700" %>
</div>

<dl class="space-y-2 text-sm max-w-lg mb-8">
  <div class="flex gap-4">
    <dt class="w-32 text-slate-500 shrink-0">Description</dt>
    <dd><%= @project_code.description %></dd>
  </div>
  <div class="flex gap-4">
    <dt class="w-32 text-slate-500 shrink-0">Status</dt>
    <dd><%= @project_code.active? ? "Active" : "Archived" %></dd>
  </div>
</dl>

<h2 class="text-base font-semibold mb-3">Assigned tasks (<%= @tasks.size %>)</h2>

<%= turbo_frame_tag "assigned-tasks-#{@project_code.id}" do %>
  <%= render 'assigned_tasks', tasks: @tasks, customer: @customer, project_code: @project_code %>
<% end %>

<div class="mt-8 border-t pt-6"
     data-controller="task-assign"
     data-task-assign-search-url-value="<%= search_tasks_customer_project_code_path(@customer, @project_code) %>">

  <h3 class="text-sm font-semibold mb-3">Assign tasks</h3>

  <textarea rows="2"
            placeholder="AW-101 AW-202 refactor auth..."
            class="w-full border rounded px-3 py-2 text-sm mb-3 font-mono"
            data-task-assign-target="query"
            data-action="input->task-assign#search"></textarea>

  <turbo-frame id="task-search-results-<%= @project_code.id %>"
               data-task-assign-target="resultsFrame"></turbo-frame>
</div>
