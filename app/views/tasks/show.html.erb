<div class="flex items-center justify-between mb-6">
  <div>
    <p class="text-xs text-slate-500 mb-1"><%= link_to "Tasks", tasks_path, class: "hover:underline" %></p>
    <h1 class="text-xl font-semibold"><%= @task.title %></h1>
  </div>
  <%= link_to "Edit", edit_task_path(@task),
      class: "px-4 py-2 bg-slate-800 text-white text-sm rounded hover:bg-slate-700" %>
</div>

<dl class="space-y-3 text-sm max-w-lg mb-8">
  <div class="flex gap-4">
    <dt class="w-36 text-slate-500 shrink-0">Customer</dt>
    <dd><%= link_to @task.customer.name, customer_path(@task.customer), class: "hover:underline" %></dd>
  </div>
  <div class="flex gap-4">
    <dt class="w-36 text-slate-500 shrink-0">Project Code</dt>
    <dd class="font-mono text-xs"><%= @task.project_code&.code || "—" %></dd>
  </div>
  <div class="flex gap-4">
    <dt class="w-36 text-slate-500 shrink-0">Billable</dt>
    <dd>
      <% if @task.billable? %>
        <span class="px-2 py-0.5 bg-green-100 dark:bg-green-900 text-green-700 dark:text-green-300 text-xs rounded-full">Yes</span>
      <% else %>
        <span class="px-2 py-0.5 bg-slate-100 dark:bg-slate-700 text-slate-500 text-xs rounded-full">No</span>
      <% end %>
    </dd>
  </div>
  <div class="flex gap-4">
    <dt class="w-36 text-slate-500 shrink-0">Invoice Name</dt>
    <dd>
      <% if @task.invoice_name.present? %>
        <%= @task.invoice_name %>
      <% else %>
        <span class="text-slate-400 italic">Generated at invoice time</span>
      <% end %>
    </dd>
  </div>
  <% if @task.notes.present? %>
    <div class="flex gap-4">
      <dt class="w-36 text-slate-500 shrink-0">Notes</dt>
      <dd class="whitespace-pre-line"><%= @task.notes %></dd>
    </div>
  <% end %>
</dl>

<div class="mt-8 max-w-lg border-t pt-6">
  <h2 class="text-base font-semibold mb-3">Ticket References</h2>
  <%= turbo_frame_tag "ticket-refs-#{@task.id}" do %>
    <%= render 'ticket_references/list', task: @task %>
  <% end %>
</div>

<div class="mt-6 max-w-lg border-t pt-6"
     data-controller="time-entry-reassign"
     data-time-entry-reassign-customer-id-value="<%= @task.customer_id %>">
  <h2 class="text-base font-semibold mb-3">Time Entries</h2>
  <% if @task.time_entries.any? %>
    <p class="text-sm font-medium mb-3">
      Total: <%= @task.time_entries.sum(:hours) %>h
    </p>
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b text-left text-slate-500">
          <th class="pb-1 font-medium">Date</th>
          <th class="pb-1 font-medium">Hours</th>
          <th class="pb-1 font-medium">Notes</th>
          <th class="pb-1"></th>
        </tr>
      </thead>
      <tbody>
        <% @task.time_entries.order(date: :desc).each do |entry| %>
          <tr class="border-b last:border-0 even:bg-slate-100 dark:even:bg-slate-700 hover:bg-slate-200 dark:hover:bg-slate-600">
            <td class="py-1 font-mono text-xs"><%= entry.date %></td>
            <td class="py-1"><%= entry.hours %>h</td>
            <td class="py-1 text-slate-500"><%= entry.notes %></td>
            <td class="py-1 text-right whitespace-nowrap">
              <% if entry.invoice_id? %>
                <span class="text-xs px-1.5 py-0.5 rounded bg-green-100 text-green-700
                             dark:bg-green-900 dark:text-green-300">billed</span>
              <% else %>
                <button type="button"
                        class="text-xs text-slate-400 hover:text-slate-600 dark:hover:text-slate-300"
                        data-action="time-entry-reassign#open"
                        data-time-entry-id="<%= entry.id %>">
                  Reassign
                </button>
                <%= button_to "Delete", time_entry_path(entry, source: "task"),
                    method: :delete,
                    form: { data: { turbo_confirm: "Delete this time entry?" } },
                    class: "text-xs text-slate-400 hover:text-red-500 ml-2" %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="text-sm text-slate-400">No time entries yet.</p>
  <% end %>

  <%# Reassign modal %>
  <div data-time-entry-reassign-target="backdrop"
       data-action="click->time-entry-reassign#close"
       class="hidden fixed inset-0 z-30 bg-black/50"></div>
  <div data-time-entry-reassign-target="modal"
       class="hidden fixed inset-0 z-40 flex items-center justify-center">
    <div class="bg-white dark:bg-slate-800 rounded shadow-lg p-4 w-full max-w-md">
      <h3 class="text-sm font-semibold mb-3">Reassign Time Entry</h3>
      <%= form_with url: "#", method: :patch, data: { time_entry_reassign_target: "form" } do %>
        <div class="relative">
          <input type="text"
                 placeholder="Search tasks…"
                 autocomplete="off"
                 class="border rounded px-3 py-2 text-sm w-full dark:bg-slate-700 dark:border-slate-600"
                 data-time-entry-reassign-target="taskInput"
                 data-action="input->time-entry-reassign#searchTask">
          <input type="hidden" name="task_id"
                 data-time-entry-reassign-target="taskIdInput">
          <turbo-frame id="task-search-results"
                       data-time-entry-reassign-target="dropdownFrame"
                       data-action="click->time-entry-reassign#selectTask"
                       class="absolute z-10 w-full top-full left-0">
          </turbo-frame>
        </div>
        <div class="flex justify-end gap-2 mt-4">
          <button type="button"
                  data-action="time-entry-reassign#close"
                  class="px-3 py-1.5 text-sm text-slate-500 hover:text-slate-700">
            Cancel
          </button>
          <button type="submit"
                  class="px-3 py-1.5 bg-slate-800 text-white text-sm rounded hover:bg-slate-700
                         dark:bg-slate-600 dark:hover:bg-slate-500">
            Reassign
          </button>
        </div>
      <% end %>
    </div>
  </div>
</div>
