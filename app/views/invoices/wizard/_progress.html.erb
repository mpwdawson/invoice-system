<nav class="flex flex-wrap gap-1 mb-6 text-xs border-b dark:border-slate-700 pb-3">
  <% @step_titles.each_with_index do |title, index| %>
    <% step_number = index + 1 %>
    <% classes = if step_number == @step
                   'font-semibold text-slate-900 dark:text-white'
                 elsif step_number <= @invoice.wizard_current_step.to_i
                   'text-slate-500 dark:text-slate-400'
                 else
                   'text-slate-300 dark:text-slate-600'
                 end %>
    <span class="px-2 py-1 rounded <%= classes %>"><%= step_number %>. <%= title %></span>
  <% end %>
</nav>
